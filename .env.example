# TMDB API (get from https://www.themoviedb.org/settings/api)
TMDB_ACCESS_TOKEN=your_tmdb_access_token_here
TMDB_API_KEY=your_tmdb_api_key_here

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your_secret_key_here

# Redis cache (optional - app works without it)
CACHE_ENABLED=0
REDIS_URL=redis://localhost:6379/0

# Per-category staleness (hours) — how long before DB data is re-fetched
STALE_TRENDING=6
STALE_POPULAR=12
STALE_HIGH_RATED=168
STALE_MOVIE_DETAIL=168
STALE_GENRES=720
STALE_SEARCH=12

# Background scheduler (set to 0 on non-leader instances)
SCHEDULER_ENABLED=1

# App
API_VERSION=v1
LOG_LEVEL=INFO
